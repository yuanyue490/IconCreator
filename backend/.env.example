# backend 环境变量示例
# 复制为 .env 后按需填写；根 .gitignore 已忽略 .env，不会提交到仓库。
# 注意：.env.example 会入库，只能保留占位值，不要填写真实密钥。
#
# 生产推荐：在此配置站长自己的 LLM 密钥。
# - 这些值只在 Node 进程里读取，不会进前端构建产物。
# - 前端若不带 apiKey 调 /api/match，后端会用这里的值兜底，
#   用户浏览器全程看不到真实 apiKey。
# - 前端若填了自己的 key（BYOK），后端优先用用户填的。

# 监听端口（默认 8787）
PORT=8787

# LLM 默认 baseURL，例如 https://api.openai.com/v1
LLM_BASE_URL=

# LLM 默认 model
LLM_MODEL=

# LLM 站长密钥（仅服务端可见，请勿放到 frontend/.env.*）
LLM_API_KEY=

# 可选：服务端默认 system prompt
LLM_SYSTEM_PROMPT=

# AI 图像生成（火山方舟 Seedream 4.5，OpenAI 兼容 images/generations）
# 默认 baseURL 为 https://ark.cn-beijing.volces.com/api/v3，按实际接入说明可覆盖。
AI_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_IMAGE_MODEL=doubao-seedream-4-5
AI_IMAGE_API_KEY=
