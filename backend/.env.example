# backend 环境变量示例
# 复制为 .env 后按需填写；根 .gitignore 已忽略 .env，不会提交到仓库。
# 注意：.env.example 会入库，只能保留占位值，不要填写真实密钥。
#
# 生产推荐：在此配置站长自己的 LLM 密钥。
# - 这些值只在 Node 进程里读取，不会进前端构建产物。
# - 前端若不带 apiKey 调 /api/match，后端会用这里的值兜底，
#   用户浏览器全程看不到真实 apiKey。
# - 前端若填了自己的 key（BYOK），后端优先用用户填的。

# 监听端口（默认 8787）
PORT=8787

# LLM 默认 baseURL，例如 https://api.openai.com/v1
LLM_BASE_URL=

# LLM 默认 model
LLM_MODEL=

# LLM 站长密钥（仅服务端可见，请勿放到 frontend/.env.*）
LLM_API_KEY=

# 可选：服务端默认 system prompt
LLM_SYSTEM_PROMPT=

# AI 图像生成（火山方舟 Seedream 4.5，OpenAI 兼容 images/generations）
# 默认 baseURL 为 https://ark.cn-beijing.volces.com/api/v3，按实际接入说明可覆盖。
AI_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_IMAGE_MODEL=doubao-seedream-4-5
AI_IMAGE_API_KEY=

# Skill 协同 · GPT Image 2 / gpt-image-2-all（API易，OpenAI images/generations 兼容）
# 注意：API易 gpt-image-2-all 不接受 size / n / quality / aspect_ratio；
# 尺寸、比例和画幅需直接写进 prompt。
APIYI_IMAGE_BASE_URL=https://api.apiyi.com/v1
APIYI_IMAGE_MODEL=gpt-image-2-all
# 可选：允许前端切换的图片模型列表，逗号分隔；只填供应商确认可用的模型。
APIYI_IMAGE_MODEL_OPTIONS=gpt-image-2-all
# 可选：服务端等待图片模型返回的最长时间，默认 120000，最大 300000。
APIYI_IMAGE_TIMEOUT_MS=120000
APIYI_IMAGE_API_KEY=
