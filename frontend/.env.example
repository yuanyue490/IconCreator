# frontend 环境变量示例
# 复制为 .env.local 后按需填写；.env.local 已在根 .gitignore 里忽略，不会提交。
#
# ⚠️ 重要安全约束
# - 所有 VITE_* 变量在构建时会被 Vite 写进前端 JS，等同于公开发布。
# - 因此 VITE_DEFAULT_LLM_API_KEY 仅在「本机开发」起作用：
#   代码里已用 import.meta.env.DEV 守卫，生产构建时编译期会把这段剔除，
#   真实 apiKey 不会出现在线上包里。
# - 生产部署时：不要设置 VITE_DEFAULT_LLM_API_KEY；
#   如需让用户默认可用，改在 backend 的环境变量里配置 LLM_API_KEY。

# LLM 服务默认 baseURL（例如 https://api.openai.com/v1）
VITE_DEFAULT_LLM_BASE_URL=

# LLM 服务默认 model
VITE_DEFAULT_LLM_MODEL=

# 仅开发期预置的 apiKey（生产构建会被编译期移除）
VITE_DEFAULT_LLM_API_KEY=

# 可选：自定义 system prompt
VITE_DEFAULT_LLM_SYSTEM_PROMPT=
