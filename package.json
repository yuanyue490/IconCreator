{
  "name": "iconcraft-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @iconcraft/shared build && concurrently \"pnpm --filter @iconcraft/backend dev\" \"pnpm --filter @iconcraft/frontend dev\"",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "catalog:names": "node scripts/generate-icon-names.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  }
}
